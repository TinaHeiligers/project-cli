#!/usr/bin/env bash
# project - Hierarchical project plan tracker
# Supports: epics → phases → steps, with per-repo and repo×target tracking
# Plans stored in ~/.projects/

set -euo pipefail

# Resolve lib/ relative to this script's real location (follow symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

source "$LIB_DIR/helpers.sh"
source "$LIB_DIR/python_helpers.sh"
source "$LIB_DIR/meta.sh"
source "$LIB_DIR/plan.sh"
source "$LIB_DIR/notes.sh"
source "$LIB_DIR/status.sh"
source "$LIB_DIR/list.sh"
source "$LIB_DIR/guide.sh"
source "$LIB_DIR/migrate.sh"

# ─── Router ───────────────────────────────────────────────────────────────────
CMD="${1:-help}"
shift || true

case "$CMD" in
  new)    cmd_new "$@" ;;
  repo)   cmd_repo "$@" ;;
  target) cmd_target "$@" ;;
  phase)  cmd_phase "$@" ;;
  step)   cmd_step "$@" ;;
  done)   cmd_mark "done" "$@" ;;
  start)  cmd_mark "wip" "$@" ;;
  reset)  cmd_mark "todo" "$@" ;;
  status) cmd_status "$@" ;;
  list)   cmd_list "$@" ;;
  note)   cmd_note "$@" ;;
  notes)  cmd_notes "$@" ;;
  edit)   cmd_edit "$@" ;;
  archive)   cmd_archive "$@" ;;
  unarchive) cmd_unarchive "$@" ;;
  migrate)   cmd_migrate "$@" ;;
  guide)  cmd_guide ;;
  help|--help|-h) cmd_help ;;
  *) die "Unknown command '$CMD'. Run: project help" ;;
esac
